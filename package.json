{
  "name": "atlas-panel",
  "version": "1.5.8",
  "private": true,
  "type": "module",
  "scripts": {
    "check:syntax": "node --check atlas.js && node --check atlas-deployer.js",
    "deploy:panel": "wrangler deploy --config wrangler.toml",
    "deploy:deployer": "wrangler deploy --config wrangler.deployer.toml",
    "dev:panel": "wrangler dev --config wrangler.toml",
    "dev:deployer": "wrangler dev --config wrangler.deployer.toml"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
